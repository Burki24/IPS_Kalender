{
    "elements": [
        {
            "type": "Configurator",
            "name": "Calendars",
            "caption": "Available calendars",
            "delete": true,
            "rowCount": 15,
            "columns": [
                {
                    "caption": "Calendar",
                    "name": "name",
                    "width": "auto"
                },
                {
                    "caption": "Color",
                    "name": "color",
                    "width": "100px"
                },
                {
                    "caption": "Access",
                    "name": "access",
                    "width": "130px"
                }
            ],
            "sort": {
                "column": "name",
                "direction": "ascending"
            },
            "values": []
        }
    ],
    "actions": [
        {
            "type": "Button",
            "caption": "Refresh calendars",
            "onClick": "IPS_RequestAction($id, 'FormRefreshCalendars', '');"
        },
        {
            "type": "PopupAlert",
            "name": "RefreshSuccessPopup",
            "visible": false,
            "popup": {
                "items": [
                    {
                        "type": "Label",
                        "caption": "Calendars refreshed."
                    }
                ]
            }
        },
        {
            "type": "PopupAlert",
            "name": "RefreshFailurePopup",
            "visible": false,
            "popup": {
                "items": [
                    {
                        "type": "Label",
                        "caption": "Calendar discovery failed. Please check the instance status for details."
                    }
                ]
            }
        }
    ],
    "status": [
        {
            "code": 201,
            "icon": "error",
            "caption": "Calendar discovery failed"
        }
    ]
}
