{
    "elements": [
        {
            "type": "CheckBox",
            "name": "Active",
            "caption": "Active"
        },
        {
            "type": "Select",
            "name": "Provider",
            "caption": "Provider",
            "onChange": "IPSKALACC_UpdateProviderForm($id, $Provider);",
            "options": [
                {
                    "caption": "Apple iCloud",
                    "value": 0
                },
                {
                    "caption": "CalDAV",
                    "value": 1
                },
                {
                    "caption": "Google Calendar",
                    "value": 2
                },
                {
                    "caption": "Microsoft 365 (planned)",
                    "value": 3
                },
                {
                    "caption": "ICS/Webcal (planned)",
                    "value": 4
                }
            ]
        },
        {
            "type": "ValidationTextBox",
            "name": "ServerURL",
            "caption": "Server URL",
            "enabled": false,
            "validate": "^$|^https?://.+"
        },
        {
            "type": "ValidationTextBox",
            "name": "Username",
            "caption": "Username"
        },
        {
            "type": "PasswordTextBox",
            "name": "Password",
            "caption": "Password"
        },
        {
            "type": "Label",
            "name": "GoogleStatus",
            "caption": "Google account is not connected.",
            "visible": false
        },
        {
            "type": "Button",
            "name": "GoogleConnect",
            "caption": "Connect Google account",
            "visible": false,
            "onClick": "echo IPSKALACC_ConnectGoogle($id);"
        },
        {
            "type": "Button",
            "name": "GoogleDisconnect",
            "caption": "Disconnect Google account",
            "visible": false,
            "confirm": "Do you really want to disconnect the Google account?",
            "onClick": "echo IPSKALACC_DisconnectGoogle($id) ? 'Google account disconnected.' : 'Could not disconnect Google account.';"
        },
        {
            "type": "NumberSpinner",
            "name": "UpdateInterval",
            "caption": "Update interval",
            "suffix": " minutes",
            "minimum": 1
        },
        {
            "type": "CheckBox",
            "name": "VerifyTLS",
            "caption": "Verify TLS certificate"
        },
        {
            "type": "NumberSpinner",
            "name": "RequestTimeout",
            "caption": "Request timeout",
            "suffix": " seconds",
            "minimum": 5,
            "maximum": 120
        }
    ],
    "actions": [
        {
            "type": "Button",
            "caption": "Test connection",
            "onClick": "echo IPSKALACC_TestConnection($id);"
        },
        {
            "type": "Button",
            "caption": "Synchronize now",
            "onClick": "echo IPSKALACC_Synchronize($id) ? 'Synchronization successful.' : 'Synchronization failed.';"
        },
        {
            "type": "Button",
            "caption": "Show account status",
            "onClick": "echo IPSKALACC_GetAccountStatus($id);"
        }
    ],
    "status": [
        {
            "code": 201,
            "icon": "error",
            "caption": "Configuration incomplete"
        },
        {
            "code": 202,
            "icon": "error",
            "caption": "Authentication failed"
        },
        {
            "code": 203,
            "icon": "error",
            "caption": "Connection failed"
        },
        {
            "code": 204,
            "icon": "inactive",
            "caption": "Provider not implemented yet"
        },
        {
            "code": 205,
            "icon": "error",
            "caption": "Invalid provider response"
        }
    ]
}
