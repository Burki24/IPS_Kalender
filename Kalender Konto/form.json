{
    "elements": [
        {
            "type": "CheckBox",
            "name": "Active",
            "caption": "Active"
        },
        {
            "type": "Select",
            "name": "Provider",
            "caption": "Provider",
            "onChange": "IPSKALACC_UpdateProviderForm($id, $Provider);",
            "options": [
                {
                    "caption": "Apple iCloud",
                    "value": 0
                },
                {
                    "caption": "CalDAV",
                    "value": 1
                },
                {
                    "caption": "Google Calendar",
                    "value": 2
                },
                {
                    "caption": "Microsoft 365 (planned)",
                    "value": 3
                },
                {
                    "caption": "ICS/Webcal",
                    "value": 4
                }
            ]
        },
        {
            "type": "ValidationTextBox",
            "name": "ServerURL",
            "caption": "Server URL",
            "enabled": false,
            "validate": "^$|^(https?|webcal)://.+"
        },
        {
            "type": "ValidationTextBox",
            "name": "Username",
            "caption": "Username"
        },
        {
            "type": "PasswordTextBox",
            "name": "Password",
            "caption": "Password"
        },
        {
            "type": "ValidationTextBox",
            "name": "CalendarName",
            "caption": "Calendar name",
            "visible": false
        },
        {
            "type": "Select",
            "name": "ICalendarTranslationProfile",
            "caption": "Title translation",
            "visible": false,
            "options": [
                {
                    "caption": "None",
                    "value": 0
                },
                {
                    "caption": "Google public calendars - German",
                    "value": 1
                }
            ]
        },
        {
            "type": "Label",
            "name": "ICalendarSubscriptionsHint",
            "caption": "Add further read-only iCalendar subscriptions here. The single feed configured above remains available for compatibility.",
            "visible": false
        },
        {
            "type": "List",
            "name": "ICalendarFeeds",
            "caption": "iCalendar subscriptions",
            "visible": false,
            "rowCount": 6,
            "add": true,
            "delete": true,
            "changeOrder": true,
            "columns": [
                {
                    "caption": "Active",
                    "name": "Active",
                    "width": "70px",
                    "add": true,
                    "edit": {
                        "type": "CheckBox"
                    }
                },
                {
                    "caption": "Calendar name",
                    "name": "Name",
                    "width": "180px",
                    "add": "iCalendar",
                    "edit": {
                        "type": "ValidationTextBox"
                    }
                },
                {
                    "caption": "iCalendar URL",
                    "name": "URL",
                    "width": "auto",
                    "add": "",
                    "edit": {
                        "type": "ValidationTextBox",
                        "validate": "^(https?|webcal)://.+"
                    }
                },
                {
                    "caption": "Username",
                    "name": "Username",
                    "width": "140px",
                    "add": "",
                    "edit": {
                        "type": "ValidationTextBox"
                    }
                },
                {
                    "caption": "Password",
                    "name": "Password",
                    "width": "120px",
                    "add": "",
                    "edit": {
                        "type": "PasswordTextBox"
                    }
                },
                {
                    "caption": "Title translation",
                    "name": "TranslationProfile",
                    "width": "190px",
                    "add": 0,
                    "edit": {
                        "type": "Select",
                        "options": [
                            {
                                "caption": "None",
                                "value": 0
                            },
                            {
                                "caption": "Google public calendars - German",
                                "value": 1
                            }
                        ]
                    }
                },
                {
                    "caption": "Synchronization schedule",
                    "name": "UpdateSchedule",
                    "width": "150px",
                    "add": 7,
                    "edit": {
                        "type": "Select",
                        "options": [
                            {
                                "caption": "Custom interval",
                                "value": 0
                            },
                            {
                                "caption": "Every 5 minutes",
                                "value": 1
                            },
                            {
                                "caption": "Every 15 minutes",
                                "value": 2
                            },
                            {
                                "caption": "Every 30 minutes",
                                "value": 3
                            },
                            {
                                "caption": "Hourly",
                                "value": 4
                            },
                            {
                                "caption": "Every 6 hours",
                                "value": 5
                            },
                            {
                                "caption": "Every 12 hours",
                                "value": 6
                            },
                            {
                                "caption": "Daily",
                                "value": 7
                            },
                            {
                                "caption": "Weekly",
                                "value": 8
                            },
                            {
                                "caption": "Monthly",
                                "value": 9
                            },
                            {
                                "caption": "Yearly",
                                "value": 10
                            },
                            {
                                "caption": "Manual only",
                                "value": 11
                            }
                        ]
                    }
                },
                {
                    "caption": "Custom interval",
                    "name": "UpdateInterval",
                    "width": "110px",
                    "add": 15,
                    "edit": {
                        "type": "NumberSpinner",
                        "minimum": 1,
                        "maximum": 525600,
                        "suffix": " minutes"
                    }
                },
                {
                    "caption": "Calendar color",
                    "name": "Color",
                    "width": "110px",
                    "add": "",
                    "edit": {
                        "type": "ValidationTextBox",
                        "validate": "^$|^#[0-9A-Fa-f]{6}$"
                    }
                }
            ]
        },
        {
            "type": "Label",
            "name": "GoogleOAuthHint",
            "caption": "Create a personal Google OAuth web client and register the redirect URI shown below.",
            "visible": false
        },
        {
            "type": "Label",
            "name": "GoogleRedirectURI",
            "caption": "Authorized redirect URI is unavailable.",
            "visible": false
        },
        {
            "type": "Button",
            "name": "GoogleShowRedirectURI",
            "caption": "Show redirect URI",
            "visible": false,
            "onClick": "$result = IPSKALACC_GetGoogleRedirectURI($id); if (str_starts_with($result, 'http://') || str_starts_with($result, 'https://')) { echo $result; } else { IPS_RequestAction($id, 'FormGoogleRedirectUnavailable', ''); }"
        },
        {
            "type": "ValidationTextBox",
            "name": "GoogleClientID",
            "caption": "Google OAuth client ID",
            "visible": false
        },
        {
            "type": "PasswordTextBox",
            "name": "GoogleClientSecret",
            "caption": "Google OAuth client secret",
            "visible": false
        },
        {
            "type": "Label",
            "name": "GoogleStatus",
            "caption": "Google account is not connected.",
            "visible": false
        },
        {
            "type": "Button",
            "name": "GoogleConnect",
            "caption": "Connect Google account",
            "visible": false,
            "onClick": "$result = IPSKALACC_ConnectGoogle($id); if (str_starts_with($result, 'http://') || str_starts_with($result, 'https://')) { echo $result; } else { IPS_RequestAction($id, 'FormGoogleAuthorizationFailed', ''); }"
        },
        {
            "type": "Button",
            "name": "GoogleDisconnect",
            "caption": "Disconnect Google account",
            "visible": false,
            "confirm": "Do you really want to disconnect the Google account?",
            "onClick": "IPSKALACC_DisconnectGoogle($id);"
        },
        {
            "type": "Select",
            "name": "UpdateSchedule",
            "caption": "Synchronization schedule",
            "onChange": "IPSKALACC_UpdateScheduleForm($id, $UpdateSchedule);",
            "options": [
                {
                    "caption": "Custom interval",
                    "value": 0
                },
                {
                    "caption": "Every 5 minutes",
                    "value": 1
                },
                {
                    "caption": "Every 15 minutes",
                    "value": 2
                },
                {
                    "caption": "Every 30 minutes",
                    "value": 3
                },
                {
                    "caption": "Hourly",
                    "value": 4
                },
                {
                    "caption": "Every 6 hours",
                    "value": 5
                },
                {
                    "caption": "Every 12 hours",
                    "value": 6
                },
                {
                    "caption": "Daily",
                    "value": 7
                },
                {
                    "caption": "Weekly",
                    "value": 8
                },
                {
                    "caption": "Monthly",
                    "value": 9
                },
                {
                    "caption": "Yearly",
                    "value": 10
                },
                {
                    "caption": "Manual only",
                    "value": 11
                }
            ]
        },
        {
            "type": "NumberSpinner",
            "name": "UpdateInterval",
            "caption": "Custom interval",
            "suffix": " minutes",
            "minimum": 1,
            "maximum": 525600
        },
        {
            "type": "CheckBox",
            "name": "VerifyTLS",
            "caption": "Verify TLS certificate"
        },
        {
            "type": "NumberSpinner",
            "name": "RequestTimeout",
            "caption": "Request timeout",
            "suffix": " seconds",
            "minimum": 5,
            "maximum": 120
        }
    ],
    "actions": [
        {
            "type": "Button",
            "caption": "Test connection",
            "onClick": "IPS_RequestAction($id, 'FormTestConnection', '');"
        },
        {
            "type": "Button",
            "caption": "Synchronize now",
            "onClick": "IPS_RequestAction($id, 'FormSynchronize', '');"
        },
        {
            "type": "Button",
            "caption": "Show account status",
            "onClick": "echo IPSKALACC_GetAccountStatus($id);"
        },
        {
            "type": "Button",
            "caption": "Clear cache",
            "confirm": "Do you really want to clear all cached calendars and feed data?",
            "onClick": "IPS_RequestAction($id, 'FormClearCache', '');"
        },
        {
            "type": "PopupAlert",
            "name": "ConnectionSuccessPopup",
            "visible": false,
            "popup": {
                "items": [
                    {
                        "type": "Label",
                        "caption": "Connection test successful."
                    }
                ]
            }
        },
        {
            "type": "PopupAlert",
            "name": "ConnectionFailurePopup",
            "visible": false,
            "popup": {
                "items": [
                    {
                        "type": "Label",
                        "caption": "Connection test failed. Please check the instance status for details."
                    }
                ]
            }
        },
        {
            "type": "PopupAlert",
            "name": "SynchronizationSuccessPopup",
            "visible": false,
            "popup": {
                "items": [
                    {
                        "type": "Label",
                        "caption": "Synchronization successful."
                    }
                ]
            }
        },
        {
            "type": "PopupAlert",
            "name": "SynchronizationFailurePopup",
            "visible": false,
            "popup": {
                "items": [
                    {
                        "type": "Label",
                        "caption": "Synchronization failed. Please check the instance status for details."
                    }
                ]
            }
        },
        {
            "type": "PopupAlert",
            "name": "CacheClearedPopup",
            "visible": false,
            "popup": {
                "items": [
                    {
                        "type": "Label",
                        "caption": "Cache cleared."
                    }
                ]
            }
        },
        {
            "type": "PopupAlert",
            "name": "GoogleAuthorizationFailedPopup",
            "visible": false,
            "popup": {
                "items": [
                    {
                        "type": "Label",
                        "caption": "Google authorization could not be started. Please check the instance status for details."
                    }
                ]
            }
        },
        {
            "type": "PopupAlert",
            "name": "GoogleRedirectUnavailablePopup",
            "visible": false,
            "popup": {
                "items": [
                    {
                        "type": "Label",
                        "caption": "Authorized redirect URI is unavailable."
                    }
                ]
            }
        }
    ],
    "status": [
        {
            "code": 201,
            "icon": "error",
            "caption": "Configuration incomplete"
        },
        {
            "code": 202,
            "icon": "error",
            "caption": "Authentication failed"
        },
        {
            "code": 203,
            "icon": "error",
            "caption": "Connection failed"
        },
        {
            "code": 204,
            "icon": "inactive",
            "caption": "Provider not implemented yet"
        },
        {
            "code": 205,
            "icon": "error",
            "caption": "Invalid provider response"
        }
    ]
}
