{
    "elements": [
        {
            "type": "CheckBox",
            "name": "Active",
            "caption": "Active"
        },
        {
            "type": "Select",
            "name": "UpdateSchedule",
            "caption": "Synchronization schedule",
            "onChange": "IPSKAL_UpdateScheduleForm($id, $UpdateSchedule);",
            "options": [
                {
                    "caption": "Custom interval",
                    "value": 0
                },
                {
                    "caption": "Every 5 minutes",
                    "value": 1
                },
                {
                    "caption": "Every 15 minutes",
                    "value": 2
                },
                {
                    "caption": "Every 30 minutes",
                    "value": 3
                },
                {
                    "caption": "Hourly",
                    "value": 4
                },
                {
                    "caption": "Every 6 hours",
                    "value": 5
                },
                {
                    "caption": "Every 12 hours",
                    "value": 6
                },
                {
                    "caption": "Daily",
                    "value": 7
                },
                {
                    "caption": "Weekly",
                    "value": 8
                },
                {
                    "caption": "Monthly",
                    "value": 9
                },
                {
                    "caption": "Yearly",
                    "value": 10
                },
                {
                    "caption": "Manual only",
                    "value": 11
                }
            ]
        },
        {
            "type": "NumberSpinner",
            "name": "UpdateInterval",
            "caption": "Custom interval",
            "suffix": " minutes",
            "minimum": 1,
            "maximum": 525600
        },
        {
            "type": "NumberSpinner",
            "name": "PastDays",
            "caption": "Load past events",
            "suffix": " days",
            "minimum": 0,
            "maximum": 1095
        },
        {
            "type": "NumberSpinner",
            "name": "FutureDays",
            "caption": "Load future events",
            "suffix": " days",
            "minimum": 1,
            "maximum": 1095
        },
        {
            "type": "ExpansionPanel",
            "caption": "Calendar identity",
            "expanded": false,
            "items": [
                {
                    "type": "ValidationTextBox",
                    "name": "CalendarID",
                    "caption": "Calendar ID",
                    "enabled": false
                },
                {
                    "type": "ValidationTextBox",
                    "name": "ProviderCalendarID",
                    "caption": "Provider calendar ID",
                    "enabled": false
                },
                {
                    "type": "ValidationTextBox",
                    "name": "CalendarURL",
                    "caption": "Calendar URL",
                    "enabled": false
                },
                {
                    "type": "ValidationTextBox",
                    "name": "CalendarColor",
                    "caption": "Calendar color",
                    "enabled": false
                },
                {
                    "type": "CheckBox",
                    "name": "CanWrite",
                    "caption": "Writable",
                    "enabled": false
                }
            ]
        }
    ],
    "actions": [
        {
            "type": "Button",
            "caption": "Synchronize now",
            "onClick": "IPS_RequestAction($id, 'FormSynchronize', '');"
        },
        {
            "type": "Button",
            "caption": "Clear cache",
            "onClick": "IPSKAL_ClearCache($id);"
        },
        {
            "type": "PopupAlert",
            "name": "SynchronizationSuccessPopup",
            "visible": false,
            "popup": {
                "items": [
                    {
                        "type": "Label",
                        "caption": "Synchronization successful."
                    }
                ]
            }
        },
        {
            "type": "PopupAlert",
            "name": "SynchronizationFailurePopup",
            "visible": false,
            "popup": {
                "items": [
                    {
                        "type": "Label",
                        "caption": "Synchronization failed. Please check the instance status for details."
                    }
                ]
            }
        }
    ],
    "status": [
        {
            "code": 201,
            "icon": "error",
            "caption": "Configuration incomplete"
        },
        {
            "code": 202,
            "icon": "error",
            "caption": "Synchronization failed"
        },
        {
            "code": 203,
            "icon": "error",
            "caption": "Invalid calendar response"
        },
        {
            "code": 204,
            "icon": "error",
            "caption": "Event write conflict"
        }
    ]
}
